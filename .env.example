# ─── GHCR (GitHub Container Registry) ────────────────────────────────────────
# GitHub username ou organização — dono dos repos ebooks-*
GHCR_OWNER=your-github-username
# Opcional: pin de versão por serviço (default: latest)
GATEWAY_TAG=latest
AUTH_TAG=latest
CATALOG_TAG=latest
COMMERCE_TAG=latest
READING_TAG=latest
NOTIFICATION_TAG=latest
SOCIAL_TAG=latest
MEDIA_TAG=latest
PARTNER_TAG=latest
WEB_TAG=latest
DELIVERY_TAG=latest
ANALYTICS_TAG=latest

# ─── BASE DE DADOS ────────────────────────────────────────────────────────────
POSTGRES_USER=ebooks
POSTGRES_PASSWORD=muda_isto_em_producao

# ─── RABBITMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=ebooks
RABBITMQ_PASSWORD=muda_isto_em_producao

# ─── MINIO ────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=ebooks_admin
MINIO_SECRET_KEY=muda_isto_em_producao

# ─── GRAFANA ──────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=muda_isto_em_producao

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=muda_isto_chave_secreta_jwt_256bits
JWT_REFRESH_SECRET=muda_isto_chave_refresh_256bits

# ─── FRONTEND ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── OAUTH ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── EMAIL (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ebooks.co.mz

# ─── REDES SOCIAIS ────────────────────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# ─── M-PESA (Vodacom Moçambique) ──────────────────────────────────────────────
MPESA_API_URL=https://api.sandbox.vm.co.mz
MPESA_API_KEY=
MPESA_PUBLIC_KEY=
MPESA_SERVICE_PROVIDER_CODE=171717

# ─── E-MOLA (Tmcel) ───────────────────────────────────────────────────────────
EMOLA_API_URL=https://api.sandbox.emola.co.mz
EMOLA_API_KEY=
EMOLA_MERCHANT_CODE=

# ─── STRIPE (Visa/Mastercard) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# ─── PAYPAL ───────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
