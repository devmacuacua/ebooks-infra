# =============================================================================
# EBooksStore — Variáveis de ambiente para desenvolvimento local
# Copiar para .env: cp .env.example .env
# Estes valores são fictícios e seguros para commitar.
# Para produção, use valores reais e NUNCA commite o .env de produção.
# =============================================================================

# ─── Base de dados ────────────────────────────────────────────────────────────
POSTGRES_USER=ebooks
POSTGRES_PASSWORD=ebooks_secret
POSTGRES_HOST=ebooks-postgres
POSTGRES_PORT=5432

# URLs por serviço (usadas internamente entre containers)
AUTH_DB_URL=postgresql://ebooks:ebooks_secret@ebooks-postgres:5432/auth_db
CATALOG_DB_URL=jdbc:postgresql://ebooks-postgres:5432/catalog_db
COMMERCE_DB_URL=jdbc:postgresql://ebooks-postgres:5432/commerce_db
READING_DB_URL=postgresql://ebooks:ebooks_secret@ebooks-postgres:5432/reading_db
NOTIFICATION_DB_URL=postgresql://ebooks:ebooks_secret@ebooks-postgres:5432/notification_db
SOCIAL_DB_URL=postgresql://ebooks:ebooks_secret@ebooks-postgres:5432/social_db
MEDIA_DB_URL=postgresql://ebooks:ebooks_secret@ebooks-postgres:5432/media_db
PARTNER_DB_URL=postgresql://ebooks:ebooks_secret@ebooks-postgres:5432/partner_db
DELIVERY_DB_URL=postgresql://ebooks:ebooks_secret@ebooks-postgres:5432/delivery_db
ANALYTICS_DB_URL=postgresql://ebooks:ebooks_secret@ebooks-postgres:5432/analytics_db

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=ebooks-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=ebooks
RABBITMQ_PASSWORD=ebooks_secret
RABBITMQ_URL=amqp://ebooks:ebooks_secret@ebooks-rabbitmq:5672

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://ebooks-redis:6379

# ─── MinIO (armazenamento de ficheiros) ───────────────────────────────────────
MINIO_ENDPOINT=http://ebooks-minio:9000
MINIO_ACCESS_KEY=ebooks_admin
MINIO_SECRET_KEY=ebooks_secret_123
MINIO_BUCKET_BOOKS=ebooks-books
MINIO_BUCKET_COVERS=ebooks-covers
MINIO_BUCKET_AVATARS=ebooks-avatars

# ─── JWT ──────────────────────────────────────────────────────────────────────
# ATENÇÃO: Gerar chave segura para produção: openssl rand -base64 64
JWT_SECRET=dev-secret-key-change-in-production-minimum-256-bits-long-string
JWT_ACCESS_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# ─── URLs de serviços (inter-serviço) ─────────────────────────────────────────
AUTH_SERVICE_URL=http://ebooks-auth-service:8081
CATALOG_SERVICE_URL=http://ebooks-catalog-service:8082
COMMERCE_SERVICE_URL=http://ebooks-commerce-service:8083
READING_SERVICE_URL=http://ebooks-reading-service:3001
NOTIFICATION_SERVICE_URL=http://ebooks-notification-service:3002
SOCIAL_SERVICE_URL=http://ebooks-social-service:3003
MEDIA_SERVICE_URL=http://ebooks-media-service:3004
PARTNER_SERVICE_URL=http://ebooks-partner-service:3005
DELIVERY_SERVICE_URL=http://ebooks-delivery-service:3006
ANALYTICS_SERVICE_URL=http://ebooks-analytics-service:3007

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SITE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_HOST=http://ebooks-elasticsearch:9200

# ─── Email (dev: usar Mailtrap ou similar) ────────────────────────────────────
# Mailtrap gratuito: https://mailtrap.io
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM=noreply@ebooks.co.mz

# ─── Firebase (push notifications) ───────────────────────────────────────────
# Criar projecto em https://console.firebase.google.com
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:000000000000
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key
FIREBASE_SERVICE_ACCOUNT_JSON={}

# ─── Stripe (pagamentos por cartão) ──────────────────────────────────────────
# Chaves de teste: https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ─── M-Pesa (pagamentos móveis — Moçambique) ─────────────────────────────────
MPESA_API_KEY=your_mpesa_api_key
MPESA_PUBLIC_KEY=your_mpesa_public_key
MPESA_SERVICE_PROVIDER_CODE=your_service_code
MPESA_BASE_URL=https://sandbox.vm.co.mz:18346

# ─── Redes sociais (publicação automática) ────────────────────────────────────
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_SECRET=your_twitter_access_secret
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
